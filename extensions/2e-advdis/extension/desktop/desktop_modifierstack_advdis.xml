<?xml version="1.0" encoding="iso-8859-1"?>

<!--
  2E ADV/DIS - Advantage & Disadvantage
  Replaces 2E's stock 5-pair modifier stack (+1..+5/-1..-5, 10 buttons)
  with a trimmed 3-pair layout matching 5E's own modifier stack: ADV/DIS,
  +2/-2, +5/-5 (6 buttons total). +1/-1, +3/-3, +4/-4 are removed.

  merge="delete" on a NAMED sheetdata control is surgical (confirmed
  against many stock examples, e.g. 2E/ps/ps_xp.xml, ICRPG/campaign/
  record_npc.xml) - unlike <tab merge="delete">, which wipes the entire
  inherited tab list. Deleting PLUS1/MINUS1/PLUS3/MINUS3/PLUS4/MINUS4
  here leaves PLUS2/MINUS2/PLUS5/MINUS5 completely untouched.

  ADV/DIS use 5E's own button width (30px, vs 2E's original 22px, which
  is too narrow for 3-letter text) and are inserted first, before the
  kept PLUS2/MINUS2. PLUS2/PLUS5 need no anchor changes themselves:
  their existing "relation=relative" left-anchor cascades based on
  document/render order, not the literal "to=" name - confirmed by the
  stock layout itself, where PLUS2 through PLUS5 all say to="modifier"
  yet already render left-to-right in sequence without overlap.

  button_modifierkey is generic CoreRPG UI that already wires
  ModifierManager.setKey("ADV"/"DIS", true) on click - no script needed
  here. The actual roll mechanic lives in scripts/manager_advdis.lua.
-->

<root>
	<windowclass name="modifierstack" merge="join">
		<sheetdata merge="join">
			<button_modifierkey name="PLUS1" merge="delete" />
			<button_modifierkey name="MINUS1" merge="delete" />
			<button_modifierkey name="PLUS3" merge="delete" />
			<button_modifierkey name="MINUS3" merge="delete" />
			<button_modifierkey name="PLUS4" merge="delete" />
			<button_modifierkey name="MINUS4" merge="delete" />

			<button_modifierkey name="ADV" insertbefore="PLUS2">
				<anchored to="modifier" width="30" height="18">
					<top offset="-4" />
					<left anchor="right" relation="relative" offset="17" />
				</anchored>
				<text>ADV</text>
			</button_modifierkey>
			<button_modifierkey name="DIS" insertbefore="PLUS2">
				<anchored to="ADV" width="30" height="18">
					<top anchor="bottom" offset="8" />
					<left anchor="left" />
				</anchored>
				<text>DIS</text>
			</button_modifierkey>
		</sheetdata>
	</windowclass>
</root>
