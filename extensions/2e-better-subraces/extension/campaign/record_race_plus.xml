<?xml version="1.0" encoding="iso-8859-1"?>

<!--
  2E Better Subraces
  - Adds Proficiencies and Advanced Effects sections to Subrace records,
    mirroring the sections a base Race already has (reference_race_main
    in the stock ruleset's campaign/record_race.xml). Subraces previously
    only had a Traits list.
  - Adds a Non-Weapon Proficiencies (Skills) section to BOTH Race and
    Subrace records. The stock addRaceSelect (manager_char.lua) already
    reads a "nonweaponprof" child list off the base Race and applies it
    to the character - there was just never any UI to author it, so it
    was dead code. This reuses the exact same list-row class the Class
    record's own working Non-Weapon Proficiencies section uses
    (ref_nonweapon_proficiency, linking reference_skill records) rather
    than the class record's slot/earn-rate mechanic, which doesn't apply
    to races (races grant specific named proficiencies directly, same as
    the existing weapon Proficiencies section already does).
  The character-apply side for Subrace (making its own proficiencies/
  effects/nonweaponprof actually apply when that subrace is chosen) is
  handled in scripts/manager_subrace_plus.lua. The base Race side needs
  no Lua changes at all - the stock function already applies it once the
  data exists.
-->

<root>
	<windowclass name="reference_race_main" merge="join">
		<script>
			function onInit()
				self.onLockModeChanged(WindowManager.getWindowReadOnlyState(self));
			end
			function onLockModeChanged(bReadOnly)
				local tFields = { "subraces_iadd", "traits_iadd", "proficiencies_iadd", "nonweaponprof_iadd", "effects_list_iadd", };
				WindowManager.callSafeControlsSetLockMode(self, tFields, bReadOnly);
			end
		</script>
		<sheetdata merge="add">
			<header_content_framed_headersimple name="nonweaponprof_header" insertbefore="advancedeffectstitle">
				<static textres="class_header_nonweaponproficiencies" />
			</header_content_framed_headersimple>
			<button_iadd name="nonweaponprof_iadd" insertbefore="advancedeffectstitle">
				<anchored to="nonweaponprof_header" position="righthigh" offset="-20,0" />
				<target>nonweaponprof</target>
			</button_iadd>
			<list_content_alternating_top name="nonweaponprof" insertbefore="advancedeffectstitle">
				<datasource>.nonweaponprof</datasource>
				<class>ref_nonweapon_proficiency</class>
			</list_content_alternating_top>
		</sheetdata>
	</windowclass>

	<!--
	  ref_nonweapon_proficiency (defined in the stock ruleset for Class
	  records) has no onInit/onLockModeChanged of its own - on Class
	  records it works because it lives inside a list_column, whose
	  built-in column_list.lua script automatically drives idelete
	  visibility/readonly state for every row via a sibling button_iedit.
	  Race/Subrace use list_content_alternating_top instead (matching
	  their other sections' look), which does none of that automatically
	  - so idelete was left unresolved (odd icon) without an explicit
	  lock-mode pairing of its own. Safe to add here since it had no
	  script at all before (nothing to collide with), and this fixes it
	  for both the Race/Subrace usage AND the original Class usage.

	  Separately: dragging a Skill record onto one of these rows silently
	  did nothing. Confirmed via a temporary diagnostic (ChatManager.
	  SystemMessage in onDrop at three levels - the row, the shortcut
	  icon, and the name field) that the drop actually lands on the
	  "name" string field, not the small shortcut icon - the icon is a
	  tiny fixed-width control, while "name" occupies the rest of the
	  row's width, so that's where a real drag lands in practice. Fixed
	  by adding an onDrop to the "name" field itself (not the shortcut
	  control) that copies the dropped record's name across and sets the
	  underlying link, mirroring the working pattern in the stock
	  ruleset's own record_power.xml.

	  Third: once drag-and-drop worked, the resulting skill entries were
	  landing under Weapon Proficiencies on the character sheet instead
	  of Non-Weapon/Skills. Root cause: CharManager.addClassProficiencyDB
	  reads a "type" field off THIS ROW (not off the linked reference_skill
	  record) to decide whether to route through addSkillRef or
	  addProficiencyDB - the stock Class record's own nonweaponprof
	  handling explicitly stamps type="skills" on its row before calling
	  addClassProficiencyDB (manager_char.lua's addClassRef), but the base
	  Race's own nonweaponprof handling never does this (meaning this
	  would have misrouted even on stock content, had any UI ever existed
	  to author it there). Fixed by stamping type="skills" (and copying
	  the skill's own "text" description, which addSkillRef also reads
	  off this row) in the same onDrop that sets name/shortcut.
	-->
	<windowclass name="ref_nonweapon_proficiency" merge="join">
		<script>
			function onInit()
				self.onLockModeChanged(WindowManager.getWindowReadOnlyState(self));
			end
			function onLockModeChanged(bReadOnly)
				WindowManager.callSafeControlsSetLockMode(self, { "name", "idelete", }, bReadOnly);
			end
		</script>
		<sheetdata merge="join">
			<string_listitem_center_bold name="name" merge="join">
				<script>
					function onDrop(x, y, draginfo)
						if draginfo.isType("shortcut") then
							local sClass, sRecord = draginfo.getShortcutData();
							if sClass == "reference_skill" then
								local nodeSource = DB.findNode(sRecord);
								if nodeSource then
									local nodeRow = window.getDatabaseNode();
									DB.setValue(nodeRow, "shortcut", "windowreference", sClass, sRecord);
									DB.setValue(nodeRow, "name", "string", DB.getValue(nodeSource, "name", ""));
									-- addClassProficiencyDB (manager_char.lua) reads "type" off
									-- THIS ROW (not the linked skill record) to decide whether to
									-- route through addSkillRef (Non-Weapon/Skills) or
									-- addProficiencyDB (Weapon Proficiencies) - without this stamp
									-- it silently falls through to the weapon-proficiency branch.
									-- Mirrors what the stock Class record's own nonweaponprof
									-- handling does (manager_char.lua's addClassRef).
									DB.setValue(nodeRow, "type", "string", "skills");
									-- addSkillRef also reads "text" off this row (not the linked
									-- skill record) for the character's copy of the skill's
									-- description.
									DB.setValue(nodeRow, "text", "formattedtext", DB.getValue(nodeSource, "text", ""));
									return true;
								end
							end
						end
					end
				</script>
			</string_listitem_center_bold>
		</sheetdata>
	</windowclass>

	<windowclass name="reference_subrace_main" merge="join">
		<script>
			function onInit()
				self.onLockModeChanged(WindowManager.getWindowReadOnlyState(self));
			end
			function onLockModeChanged(bReadOnly)
				local tFields = { "traits_iadd", "proficiencies_iadd", "nonweaponprof_iadd", "effects_list_iadd", };
				WindowManager.callSafeControlsSetLockMode(self, tFields, bReadOnly);
			end
		</script>
		<sheetdata merge="add">
			<header_content_framed_headersimple name="proficiencies_header">
				<static textres="race_header_proficiencies" />
			</header_content_framed_headersimple>
			<button_iadd name="proficiencies_iadd">
				<anchored to="proficiencies_header" position="righthigh" offset="-20,0" />
				<target>proficiencies</target>
			</button_iadd>
			<list_content_alternating_top name="proficiencies">
				<datasource>.proficiencies</datasource>
				<class>ref_racial_proficiencies</class>
			</list_content_alternating_top>

			<header_content_framed_headersimple name="nonweaponprof_header">
				<static textres="class_header_nonweaponproficiencies" />
			</header_content_framed_headersimple>
			<button_iadd name="nonweaponprof_iadd">
				<anchored to="nonweaponprof_header" position="righthigh" offset="-20,0" />
				<target>nonweaponprof</target>
			</button_iadd>
			<list_content_alternating_top name="nonweaponprof">
				<datasource>.nonweaponprof</datasource>
				<class>ref_nonweapon_proficiency</class>
			</list_content_alternating_top>

			<header_content_framed_headersimple name="advancedeffectstitle">
				<static textres="char_abilities_label_advancedeffects" />
			</header_content_framed_headersimple>
			<button_iadd name="effects_list_iadd">
				<anchored to="advancedeffectstitle" position="insidetopright" offset="-5,0" />
				<target>effects_list</target>
			</button_iadd>
			<list_content_alternating_top name="effects_list">
				<datasource>.effectlist</datasource>
				<class>advanced_effects_entry2</class>
			</list_content_alternating_top>
		</sheetdata>
	</windowclass>
</root>
