<?xml version="1.0" encoding="iso-8859-1"?>

<!--
  2E KPI - Kits, Parcels, and Items
  Replaces the Kit (reference_background) Weapon tab with a Parcels tab.
  Kits hold links to Treasure Parcels; applying the Kit to a character
  unpacks each linked Parcel onto the character, using the same generic
  parcel-expansion mechanism CoreRPG itself uses everywhere else (NPCs,
  party sheet, other parcels). Drag the same Parcel on twice for multiple
  copies rather than using a count field.
-->

<root>
	<windowclass name="reference_background" merge="join">
		<tab merge="delete" />

		<tab merge="add">
			<name>notes</name>
			<resource>tab_main</resource>
			<class>record_content_text</class>
			<embed />
		</tab>
		<tab merge="add">
			<name>main</name>
			<resource>tab_other</resource>
			<class>reference_background_main</class>
			<embed />
		</tab>
		<tab merge="add">
			<name>skills</name>
			<resource>tab_skills</resource>
			<class>recordslist_skills_contents</class>
			<embed />
		</tab>
		<tab merge="add">
			<name>kpiparcels</name>
			<resource>kpi_tab_parcels</resource>
			<class>kpi_background_parcels</class>
			<embed />
		</tab>
		<tab merge="add">
			<name>spellactions</name>
			<resource>tab_powers</resource>
			<class>recordslist_actions_powers</class>
			<embed />
		</tab>

		<script>
			function onDrop(x, y, draginfo)
				local nodeKit = getDatabaseNode();
				if draginfo.isType("shortcut") then
					local sClass = draginfo.getShortcutData();
					if sClass == "treasureparcel" then
						if DB.getValue(nodeKit, "locked", 0) == 1 then
							return false;
						end
						return KPIManager.addParcelLink(nodeKit, draginfo);
					end
				end
				return UtilityManagerADND.onDropStory(x, y, draginfo, nodeKit);
			end
		</script>
	</windowclass>

	<windowclass name="kpi_background_parcels">
		<margins control="0,0,0,7" />
		<sheetdata>
			<anchor_column name="columnanchor" />

			<header_column name="parcels_header">
				<static textres="kpi_label_parcels" />
				<center />
			</header_column>
			<list_column name="parcellist">
				<datasource>.parcellist</datasource>
				<class>kpi_parcel</class>
				<empty textres="kpi_emptylist_parcels" />
			</list_column>
		</sheetdata>
	</windowclass>

	<windowclass name="kpi_parcel">
		<margins control="0,0,0,2" />
		<script>
			function onInit()
				self.onLockModeChanged(WindowManager.getWindowReadOnlyState(self));
				viewicon.setIcons(Interface.getLinkIcon("treasureparcel"), Interface.getLinkIcon("treasureparcel"));
			end
			function onLockModeChanged(bReadOnly)
				WindowManager.callSafeControlsSetLockMode(self, { "name", "idelete", }, bReadOnly);
			end
		</script>
		<sheetdata>
			<anchor_listitem_left_sm />
			<anchor_listitem_right_sm />

			<button_listitem_idelete_left name="idelete" />

			<!--
			  This link field stores the actual parcel reference (read by
			  addKitParcels for the real apply-to-character unpack) and
			  accepts drops bubbled up from the tab's own onDrop, but is not
			  shown or clickable itself - the real "treasureparcel" window's
			  click-to-follow-link behavior can't be suppressed from script
			  (onClickDown returning true does not stop it from also
			  firing), and that window doesn't render correctly when opened
			  this way. See viewicon below for the working substitute.
			-->
			<linkc_listitem_left name="link">
				<anchored width="20" height="20">
					<top />
					<left offset="2" />
				</anchored>
				<class>treasureparcel</class>
				<nodrag />
				<invisible />
			</linkc_listitem_left>

			<buttoncontrol name="viewicon">
				<anchored to="idelete" position="righthigh" offset="4,0" width="20" height="20" />
				<script>
					function onButtonPress()
						local nodeRow = window.getDatabaseNode();
						if not nodeRow then
							return;
						end
						Interface.openWindow("kpi_parcel_preview", DB.getPath(nodeRow));
					end
				</script>
			</buttoncontrol>

			<string_listitem_center_underline name="name">
				<anchored height="20">
					<top />
					<left parent="viewicon" anchor="right" relation="relative" offset="4" />
					<right offset="-5" />
				</anchored>
				<empty textres="library_recordtype_empty_treasureparcel" />
			</string_listitem_center_underline>
		</sheetdata>
	</windowclass>

	<!--
	  Read-only summary popup for a Parcel linked on a Kit. Reads pre-cached
	  "coinsummary"/"itemsummary" fields stored on the Kit's own row (set by
	  KPIManager.addParcelLink when the Parcel was dropped) rather than the
	  live parcel's own coinlist/itemlist - reading those directly at preview
	  time returned empty even via plain DB.* calls (not just the real
	  "treasureparcel" windowclass's own sub_content), while the exact same
	  reads succeed reliably at drop-time and character-apply-time. Bound to
	  the ROW's own path, not the parcel's.
	-->
	<windowclass name="kpi_parcel_preview">
		<frame>recordsheet</frame>
		<placement>
			<size width="350" height="400" />
		</placement>
		<sizelimits>
			<minimum width="280" height="200" />
			<dynamic />
		</sizelimits>
		<script>
			function onInit()
				local nodeRow = getDatabaseNode();
				if not nodeRow then
					return;
				end

				header.setValue(DB.getValue(nodeRow, "name", ""));
				coins.setValue(DB.getValue(nodeRow, "coinsummary", "(none)"));
				items.setValue(DB.getValue(nodeRow, "itemsummary", "(none)"));
			end
		</script>
		<sheetdata>
			<stringcontrol name="header">
				<bounds>10,10,320,24</bounds>
				<readonly />
			</stringcontrol>

			<stringcontrol name="coins_label">
				<bounds>10,44,80,20</bounds>
				<static><text>Coins:</text></static>
			</stringcontrol>
			<stringcontrol name="coins">
				<bounds>95,44,235,100</bounds>
				<readonly />
				<multilinespacing>18</multilinespacing>
			</stringcontrol>

			<stringcontrol name="items_label">
				<bounds>10,154,80,20</bounds>
				<static><text>Items:</text></static>
			</stringcontrol>
			<stringcontrol name="items">
				<bounds>95,154,235,230</bounds>
				<readonly />
				<multilinespacing>18</multilinespacing>
			</stringcontrol>
		</sheetdata>
	</windowclass>
</root>
